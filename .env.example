# League Watcher Bot - Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git

# Discord Bot Configuration
# Get your bot token from https://discord.com/developers/applications
BOT_DISCORD_TOKEN=your_discord_bot_token_here

# Discord Owner ID
# This is your Discord USERNAME (e.g., "cauchy2384"), NOT the numeric user ID
BOT_OWNER_ID=your_discord_username

# Optional: Log level
# Options: info, debug, error
# Default: info
LOG_LEVEL=info
